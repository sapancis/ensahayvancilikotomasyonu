@model ciftlik2.Models.TedaviKaydi

@{
    ViewData["Title"] = "Tedavi Kaydını Sil";
}

<div class="page-container">
    <div class="page-header">
        <h1><i class="fa-solid fa-trash"></i> Tedavi Kaydını Sil</h1>
    </div>

    <div class="delete-container">
        <h3>Bu tedavi kaydını silmek istediğinizden emin misiniz?</h3>
        <p>Bu işlem geri alınamaz.</p>

        <div class="record-details">
            <dl>
                <dt>Hayvan:</dt>
                <dd>@Model.Hayvan?.KupeNumarasi - @Model.Hayvan?.Ad</dd>

                <dt>Teşhis:</dt>
                <dd>@Model.Teshis</dd>

                <dt>Kullanılan İlaç:</dt>
                <dd>@Model.KullanilanIlac</dd>

                <dt>Süt Arınma Tarihi:</dt>
                <dd>@Model.SutArinmaTarihi?.ToString("dd.MM.yyyy")</dd>
            </dl>
        </div>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />

            <div class="delete-actions">
                <input type="submit" value="Evet, Sil" class="btn btn-delete" />
                <a asp-action="Index" class="btn btn-outline">İptal</a>
            </div>
        </form>
    </div>
</div>