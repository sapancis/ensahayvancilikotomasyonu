@model ciftlik2.Models.TedaviKaydi

@{
    ViewData["Title"] = "Yeni Tedavi";
}

<div class="form-container">
    <h2 class="mb-4" style="color: var(--primary-green); border-bottom: 2px solid #eee; padding-bottom: 10px;">
        <i class="fa-solid fa-notes-medical"></i> Yeni Tedavi Kaydı
    </h2>

    <form asp-action="Create" class="form-grid">
        <div asp-validation-summary="ModelOnly" class="text-danger" style="grid-column: span 2;"></div>

        <!-- HAYVAN SEÇİMİ (Dropdown) -->
        <div class="form-group">
            <label asp-for="HayvanId" class="form-label">Hasta Hayvan Seçimi</label>
            <div class="input-group">
                <span class="input-group-text" style="background-color: #e8f5e9; color: var(--primary-green); border-color: #ced4da;">
                    <i class="fa-solid fa-cow"></i>
                </span>
                <select asp-for="HayvanId" class="form-control" asp-items="ViewBag.HayvanListesi">
                    <option value="">-- Hayvan Seçiniz --</option>
                </select>
            </div>
            <span asp-validation-for="HayvanId" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Teshis" class="form-label">Teşhis / Hastalık</label>
            <input asp-for="Teshis" class="form-control" placeholder="Örn: Mastitis, Şap..." />
            <span asp-validation-for="Teshis" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="KullanilanIlac" class="form-label">Kullanılan İlaç / Tedavi</label>
            <input asp-for="KullanilanIlac" class="form-control" />
            <span asp-validation-for="KullanilanIlac" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="SutArinmaTarihi" class="form-label">Süt Arınma Tarihi (Varsa)</label>
            <input asp-for="SutArinmaTarihi" type="date" class="form-control" />
            <small class="text-muted" style="font-size: 0.85rem;">
                <i class="fa-solid fa-circle-info"></i> Bu tarihe kadar sütün dökülmesi gerektiği sistemde uyarı olarak görünecektir.
            </small>
            <span asp-validation-for="SutArinmaTarihi" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="ReceteyiYazanVeteriner" class="form-label">Reçeteyi Yazan</label>
            <input asp-for="ReceteyiYazanVeteriner" class="form-control" />
            <span asp-validation-for="ReceteyiYazanVeteriner" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="DenetleyenVeteriner" class="form-label">Uygulayan Kişi</label>
            <input asp-for="DenetleyenVeteriner" class="form-control" />
            <span asp-validation-for="DenetleyenVeteriner" class="text-danger"></span>
        </div>

        <!-- BUTONLAR -->
        <div class="form-group" style="grid-column: span 2; margin-top: 20px;">
            <button type="submit" class="btn btn-primary btn-lg w-100">
                <i class="fa-solid fa-save"></i> Kaydet
            </button>
            <a asp-action="Index" class="btn btn-secondary w-100 mt-2">
                <i class="fa-solid fa-times"></i> İptal
            </a>
        </div>
        <div class="form-group">
            <label asp-for="TedaviUcreti" class="form-label">Tedavi Ücreti / Maliyet</label>
            <div class="input-group">
                <input asp-for="TedaviUcreti" type="number" step="0.01" class="form-control" placeholder="0.00" />
                <span class="input-group-text">₺</span>
            </div>
            <span asp-validation-for="TedaviUcreti" class="text-danger"></span>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}