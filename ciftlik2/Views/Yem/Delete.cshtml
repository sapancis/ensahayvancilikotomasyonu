@model ciftlik2.Models.YemAlisi

@{
    ViewData["Title"] = "Yem Alış Kaydını Sil";
}

<div class="page-container">
    <div class="page-header">
        <h1><i class="fa-solid fa-trash"></i> Yem Alış Kaydını Sil</h1>
    </div>

    <div class="delete-container">
        <h3>Bu yem alım kaydını silmek istediğinizden emin misiniz?</h3>
        <p>Bu işlem geri alınamaz.</p>

        <div class="record-details">
            <dl>
                <dt>Alış Tarihi:</dt>
                <dd>@Model.AlisTarihi.ToString("dd.MM.yyyy")</dd>

                <dt>Yem Türü:</dt>
                <dd>@Model.YemTuru.ToString()</dd>

                <dt>Toplam Fiyat:</dt>
                <dd>@Model.ToplamFiyat.ToString("C2")</dd>
            </dl>
        </div>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />

            <div class="delete-actions">
                <input type="submit" value="Evet, Sil" class="btn btn-delete" />
                <a asp-action="Index" class="btn btn-outline">İptal</a>
            </div>
        </form>
    </div>
</div>