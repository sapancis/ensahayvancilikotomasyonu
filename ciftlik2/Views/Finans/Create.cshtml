@model ciftlik2.Models.FinansIslemi
@using ciftlik2.Models.Enums

@{
    ViewData["Title"] = "Yeni Finansal İşlem";
}

<div class="form-container">
    <h2 class="mb-4" style="color:var(--primary-green); border-bottom:2px solid #eee; padding-bottom:10px;">
        <i class="fa-solid fa-file-invoice-dollar"></i> Yeni Gelir/Gider Kaydı
    </h2>
    <form asp-action="Create" class="form-grid">
        <div class="form-group">
            <label asp-for="Tarih" class="form-label"></label>
            <input asp-for="Tarih" type="date" class="form-control" />
        </div>
        <div class="form-group">
            <label asp-for="Tur" class="form-label">İşlem Türü</label>
            <select asp-for="Tur" class="form-control" asp-items="Html.GetEnumSelectList<IslemTuru>()"></select>
        </div>
        <div class="form-group">
            <label asp-for="Kategori" class="form-label">Kategori</label>
            <select asp-for="Kategori" class="form-control" asp-items="Html.GetEnumSelectList<FinansKategorisi>()"></select>
        </div>
        <div class="form-group">
            <label asp-for="Tutar" class="form-label">Tutar (TL)</label>
            <input asp-for="Tutar" type="number" step="0.01" class="form-control" />
        </div>
        <div class="form-group col-span-2">
            <label asp-for="Aciklama" class="form-label">Açıklama</label>
            <input asp-for="Aciklama" class="form-control" />
        </div>
        <div class="form-footer-grid col-span-2">
            <a asp-action="Index" class="btn btn-secondary">İptal</a>
            <button type="submit" class="btn btn-primary">Kaydet</button>
        </div>
    </form>
</div>