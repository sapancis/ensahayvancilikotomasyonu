@model ciftlik2.Models.FinansRaporViewModel

@{
    ViewData["Title"] = "Finansal Durum";
    string activeFilter = ViewBag.ActiveFilter as string;
    string filterText = ViewBag.FilterText as string;
}

<div class="page-container">

    <!-- BAŞLIK VE FİLTRE BUTONLARI -->
    <div class="page-header">
        <div class="d-flex align-items-center gap-3">
            <h1><i class="fa-solid fa-chart-line"></i> Finansal Durum</h1>
            <span class="badge bg-secondary" style="font-size: 1rem; font-weight: 500;">@filterText</span>
        </div>

        <div class="d-flex gap-2">
            <!-- FİLTRE BUTONLARI -->
            <div class="btn-group" role="group">
                <a asp-action="Index" asp-route-filter="aylik" class="btn @(activeFilter == "aylik" ? "btn-primary" : "btn-outline")">
                    Bu Ay
                </a>
                <a asp-action="Index" asp-route-filter="yillik" class="btn @(activeFilter == "yillik" ? "btn-primary" : "btn-outline")">
                    Bu Yıl
                </a>
            </div>

            <a asp-action="Create" class="btn btn-success ms-3">
                <i class="fa-solid fa-plus"></i> Fatura/Gider Ekle
            </a>
        </div>
    </div>

    <!-- ÖZET KARTLAR -->
    <div class="dashboard-stats-grid mb-4">
        <div class="stat-card green">
            <div class="stat-icon"><i class="fa-solid fa-arrow-trend-up"></i></div>
            <div class="stat-info">
                <h3>Toplam Gelir (@filterText)</h3>
                <h2>@Model.ToplamGelir.ToString("N2") ₺</h2>
            </div>
        </div>
        <div class="stat-card red">
            <div class="stat-icon"><i class="fa-solid fa-arrow-trend-down"></i></div>
            <div class="stat-info">
                <h3>Toplam Gider (@filterText)</h3>
                <h2>@Model.ToplamGider.ToString("N2") ₺</h2>
            </div>
        </div>
        <div class="stat-card @(Model.NetKar >= 0 ? "blue" : "orange")">
            <div class="stat-icon"><i class="fa-solid fa-wallet"></i></div>
            <div class="stat-info">
                <h3>Net Kâr / Zarar</h3>
                <h2>@Model.NetKar.ToString("N2") ₺</h2>
            </div>
        </div>
    </div>

    <div class="row" style="display:flex; flex-wrap:wrap; gap:20px;">
        <!-- GRAFİK -->
        <div class="col-md-6" style="flex:1; min-width:300px;">
            <div class="chart-container">
                <div class="chart-title">Gider Dağılımı (@filterText)</div>
                <!-- Veri yoksa uyarı göster -->
                @if (Model.ToplamGider == 0)
                {
                    <div class="empty-state">
                        <i class="fa-solid fa-chart-pie"></i>
                        <p>Henüz gider kaydı yok.</p>
                    </div>
                }
                else
                {
                    <canvas id="giderChart"></canvas>
                }
            </div>
        </div>

        <!-- TABLO -->
        <div class="col-md-6" style="flex:1; min-width:300px;">
            <div class="chart-container" style="height:auto; min-height:400px;">
                <div class="chart-title">Hesap Hareketleri (@filterText)</div>
                <div class="table-responsive-wrapper" style="box-shadow:none; border:none; max-height: 400px; overflow-y: auto;">
                    <table class="data-table">
                        <thead>
                            <tr><th>Tarih</th><th>İşlem</th><th class="text-end">Tutar</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.SonHareketler)
                            {
                                <tr>
                                    <td><span class="date-cell">@item.Tarih.ToString("dd.MM")</span></td>
                                    <td>
                                        <strong>@item.Tur</strong><br>
                                        <small class="text-muted">@item.Aciklama</small>
                                    </td>
                                    <td class="text-end">
                                        @if (item.GelirMi)
                                        {
                                            <span class="text-success fw-bold">+@item.Tutar.ToString("N2") ₺</span>
                                        }
                                        else
                                        {
                                            <span class="text-danger fw-bold">-@item.Tutar.ToString("N2") ₺</span>
                                        }
                                    </td>
                                </tr>
                            }
                            @if (!Model.SonHareketler.Any())
                            {
                                <tr>
                                    <td colspan="3" class="text-center text-muted p-4">Kayıt bulunamadı.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Grafik Scripti -->
<script>
    document.addEventListener("DOMContentLoaded", function() {
        const ctx = document.getElementById('giderChart');

        if(ctx) {
            new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: ['Yem', 'Tedavi', 'Hayvan Alımı', 'Genel Giderler'],
                    datasets: [{
                        data: [
                            @Model.GiderYem.ToString(System.Globalization.CultureInfo.InvariantCulture),
                            @Model.GiderTedavi.ToString(System.Globalization.CultureInfo.InvariantCulture),
                            @Model.GiderHayvanAlim.ToString(System.Globalization.CultureInfo.InvariantCulture),
                            @Model.GiderGenel.ToString(System.Globalization.CultureInfo.InvariantCulture)
                        ],
                        backgroundColor: ['#FF6384', '#36A2EB', '#FFCE56', '#4BC0C0'],
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'bottom' }
                    }
                }
            });
        }
    });
</script>