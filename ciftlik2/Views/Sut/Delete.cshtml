@model ciftlik2.Models.SutKaydi

@{
    ViewData["Title"] = "Kayıt Sil";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-danger">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0"><i class="fa-solid fa-triangle-exclamation"></i> Kayıt Silme Onayı</h5>
                </div>
                <div class="card-body">
                    <h4 class="card-title text-center text-danger mb-4">Bu kaydı silmek istediğine emin misin?</h4>

                    <dl class="row">
                        <dt class="col-sm-5 text-muted">Tarih:</dt>
                        <dd class="col-sm-7 fw-bold">@Model.Tarih.ToString("dd.MM.yyyy")</dd>

                        <dt class="col-sm-5 text-muted">Vakit:</dt>
                        <dd class="col-sm-7">@Model.Vakit</dd>

                        <dt class="col-sm-5 text-muted">Miktar:</dt>
                        <dd class="col-sm-7">@Model.Miktar Lt</dd>
                    </dl>

                    <div class="alert alert-warning mt-3">
                        <small>Bu işlem geri alınamaz.</small>
                    </div>

                    <form asp-action="Delete" method="post" class="d-flex justify-content-between mt-4">
                        <!-- ID'yi gizli olarak taşıyoruz -->
                        <input type="hidden" asp-for="Id" />

                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="fa-solid fa-arrow-left"></i> Vazgeç
                        </a>

                        <button type="submit" class="btn btn-danger">
                            <i class="fa-solid fa-trash"></i> Evet, Sil
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>