@model ciftlik2.Models.Kullanici

@{
    // 1. ADIM: Ana Layout'u (yeşil menü) devre dışı bırak
    Layout = null;
    ViewData["Title"] = "Giriş Yap";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ÇiftlikYönetim</title>

    <style>
        /* Projedeki ana renkleri burada da tanımlayalım */
        :root {
            --primary-green: #2E7D32;
            --accent-green: #4CAF50;
            --light-gray: #f0f2f5;
            --text-color: #333;
            --white-color: #ffffff;
            --border-color: #e0e0e0;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            margin: 0;
            padding: 0;
            background-color: var(--light-gray);
            /* Sayfanın ortasında dikey ve yatay olarak hizala */
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh; /* Ekranı kapla */
        }

        /* Giriş Kartı */
        .login-box {
            background-color: var(--white-color);
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
            width: 100%;
            max-width: 400px;
            text-align: center;
        }

        /* Logo/Başlık (ÇiftlikYönetim) */
        .login-logo {
            font-size: 1.8rem;
            font-weight: 700;
            color: var(--primary-green);
            margin-bottom: 25px;
        }

            .login-logo .fa-tractor {
                margin-right: 10px;
                color: var(--accent-green);
            }

        /* Form Elemanları */
        .form-group {
            margin-bottom: 20px;
            text-align: left;
        }

        .form-label {
            font-weight: 600;
            margin-bottom: 8px;
            display: block;
            color: #555;
        }

        .form-control {
            width: 100%;
            padding: 12px 15px;
            border: 1px solid var(--border-color);
            border-radius: 8px;
            font-size: 1rem;
            box-sizing: border-box; /* Önemli */
        }

            .form-control:focus {
                outline: none;
                border-color: var(--primary-green);
                box-shadow: 0 0 0 3px rgba(46, 125, 50, 0.15);
            }

        /* Giriş Butonu */
        .btn-login {
            width: 100%;
            padding: 15px;
            border: none;
            border-radius: 8px;
            background-color: var(--accent-green);
            color: var(--white-color);
            font-size: 1.1rem;
            font-weight: 600;
            cursor: pointer;
            transition: background-color 0.3s ease;
        }

            .btn-login:hover {
                background-color: var(--primary-green);
            }

        /* Hata Mesajları */
        .text-danger {
            color: #E91E63;
            font-size: 0.9rem;
            margin-top: 5px;
        }

        .validation-summary-errors {
            text-align: left;
            padding: 10px;
            background-color: #fdd;
            border: 1px solid #E91E63;
            border-radius: 8px;
            margin-bottom: 15px;
        }
    </style>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
</head>
<body>

    <div class="login-box">
        <div class="login-logo">
            <i class="fa-solid fa-tractor"></i>
            ÇiftlikYönetim
        </div>

        <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">

            <div asp-validation-summary="ModelOnly" class="text-danger validation-summary-errors"></div>

            <div class="form-group">
                <label asp-for="KullaniciAdi" class="form-label">Kullanıcı Adı</label>
                <input asp-for="KullaniciAdi" class="form-control" placeholder="Kullanıcı adınızı girin" />
                <span asp-validation-for="KullaniciAdi" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Sifre" class="form-label">Şifre</label>
                <input asp-for="Sifre" class="form-control" placeholder="Şifrenizi girin" />
                <span asp-validation-for="Sifre" class="text-danger"></span>
            </div>

            <div class="form-group" style="margin-top: 30px;">
                <input type="submit" value="Giriş Yap" class="btn-login" />
            </div>
        </form>
    </div>

    @await Html.PartialAsync("_ValidationScriptsPartial")
</body>
</html>